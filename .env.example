# ── Frontend build args (baked into the React bundle at build time) ───────────
# Public URL of your backend API (must be reachable from the user's browser)
VITE_API_URL=http://<YOUR_VM_IP>:5001/api

# Google OAuth client ID
VITE_GOOGLE_CLIENT_ID=

# Set to "true" to use VM local storage instead of Cloudinary
VITE_USE_LOCAL_STORAGE=true

# Leave blank when using local storage
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Razorpay public key
VITE_RAZORPAY_KEY_ID=
