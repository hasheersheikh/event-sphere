# Backend Environment Variables
PORT=5001
MONGODB_URI=mongodb://localhost:27017/event-sphere
JWT_SECRET=your_jwt_secret_here

# Resend Email Service
RESEND_API_KEY=re_your_api_key

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend URL for emails
FRONTEND_URL=http://localhost:8080

# Admin Configuration
ADMIN_EMAIL=admin@eventsphere.dev

# Local file storage (set to "true" to serve uploads from VM disk instead of Cloudinary)
USE_LOCAL_STORAGE=false
# Public URL of this backend (used to build upload URLs returned to the frontend)
BACKEND_URL=http://localhost:5001
